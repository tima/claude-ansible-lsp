{
  "name": "ansible-lsp",
  "version": "1.0.0",
  "description": "Ansible language server for enhanced playbook and role intelligence",
  "author": {
    "name": "Tim Appnel"
  },
  "license": "MIT",
  "lspServers": {
    "ansible": {
      "command": "node",
      "args": [
        "node_modules/@ansible/ansible-language-server/dist/cli.cjs",
        "--stdio"
      ],
      "extensionToLanguage": {
        ".yml": "ansible",
        ".yaml": "ansible"
      }
    }
  }
}
