{
  "name": "ansible-lsp",
  "version": "1.0.0",
  "description": "Ansible language server for enhanced playbook and role intelligence",
  "author": {
    "name": "Tim Appnel"
  },
  "license": "MIT",
  "lspServers": {
    "ansible": {
      "command": "ansible-language-server",
      "args": ["--stdio"],
      "extensionToLanguage": {
        ".yml": "ansible",
        ".yaml": "ansible"
      }
    }
  }
}
